{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "physstimu:xiaobo_block_phys",
      "materials": {
        "default": "skeleton"
      },
      "textures": {
        "default": "textures/entity/physxblock"
      },
      "geometry": {
        "default": "geometry.skeleton.v1.8"
      },
      "render_controllers": [
        {
          "controller.render.physxblock": "!variable.is_blocking"
        },
        {
          "controller.render.physxblock_no_lighting": "variable.is_blocking"
        }
      ],
      
      "scripts": {
        "pre_animation": [
          "variable.is_blocking = query.blocking;"
        ],
        "should_update_effects_offscreen": "1.0",
        "should_update_bones_and_effects_offscreen": "1.0"
      },
      "spawn_egg": {
        "base_color": "#db7500",
        "overlay_color": "#242222"
      }
    }
  }
}